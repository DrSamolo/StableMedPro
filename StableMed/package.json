    "test:rls": "node --test tests/rls-audit.test.mjs",
    "test:auth-middleware": "node --experimental-strip-types --experimental-specifier-resolution=node --test tests/middleware-auth.test.ts",
    "perf:seed": "node scripts/perf/seed-leads.mjs",
    "perf:bench": "node scripts/perf/bench-leads.mjs",
    "perf:100k:run": "node scripts/perf/run-100k-ready.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "2",
    "@tanstack/react-query": "^5.90.7",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "^15.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.65.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {

  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "dev:webpack": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "preview": "next start -p 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint && npm test",
    "verify:strict": "npm run lint && npm run typecheck",
